# Copy to .env.development (Gatsby loads it automatically in `npm run develop`).
# Tracked example only — do not commit real secrets.

# API base URL (no trailing slash). Browser calls this from your machine.
GATSBY_API_URL=http://localhost:3001/api

# If your team provides a staging API and CORS allows localhost:8000, you can use e.g.:
# GATSBY_API_URL=https://api.example.org/api
