DB_HOST=
DB_PORT=5432
DB_NAME=petadex
DB_USER=
DB_PASS=

# change this if you run the backend on a different port than your Gatsby site
PORT=3001

# iTOL batch upload (trees prototype) — API key from iTOL account (User info / batch access)
