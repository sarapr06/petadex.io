    "ApiLambdaFunctionQualifiedArn": {
      "Description": "Current Lambda function version",
      "Value": {
        "Ref": "ApiLambdaVersionPMGynokhWX9jwGRRJBuA7LXCkJcaeAc93Adj7Xyo3U"
      },
      "Export": {
        "Name": "sls-petadex-backend-dev-ApiLambdaFunctionQualifiedArn"
      }
    },
    "HttpApiId": {
